{
  "name": "ai-agent-house",
  "version": "0.2.0",
  "description": "A lightweight framework for multi-AI-agent cohabitation — where AI agents live together, share memory, and collaborate like roommates. 🏠🤖",
  "keywords": [
    "ai",
    "agent",
    "multi-agent",
    "mcp",
    "llm",
    "openai",
    "anthropic",
    "google",
    "framework",
    "orchestration",
    "collaboration"
  ],
  "author": "California0105",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ai-house": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agents": {
      "import": "./dist/agents/index.js",
      "types": "./dist/agents/index.d.ts"
    },
    "./memory": {
      "import": "./dist/memory/index.js",
      "types": "./dist/memory/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "types": "./dist/tools/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "nanoid": "^5.1.5",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.22.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "openai": "^5.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "better-sqlite3": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true },
    "@google/generative-ai": { "optional": true },
    "better-sqlite3": { "optional": true }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/California0105/ai-agent-house.git"
  },
  "bugs": {
    "url": "https://github.com/California0105/ai-agent-house/issues"
  },
  "homepage": "https://github.com/California0105/ai-agent-house#readme"
}
